generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int       @id @default(autoincrement())
  email      String    @unique
  password   String
  name       String?
  isAdmin    Boolean   @default(false)

  cart       Cart      @relation(fields: [cartId], references: [id])
  cartId     Int       @unique
  }

model Cart {
  id         Int       @id @default(autoincrement())
  user       User?
  
}
