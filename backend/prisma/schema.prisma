generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String    
  name      String?
  isAdmin   Boolean   @default(false)

  cart      Cart      @relation(fields: [cartId], references: [id])
  cartId    Int       @unique
  }

model Product {
  id        Int       @id @default(autoincrement())
  
}

model Cart {
  id        Int       @id @default(autoincrement())
  user      User?
}

model CartItem {
  id        Int       @id @default(autoincrement())
}

model Order{
  id        Int       @id @default(autoincrement())
}

model OrderItem{
  id        Int       @id @default(autoincrement())
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    
}
